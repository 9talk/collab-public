{
  "productName": "Collaborator",
  "version": "0.1.0",
  "identifier": "com.collaborator.desktop",
  "build": {
    "beforeDevCommand": "bun install && bun run vite dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun install && bun run vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Collaborator",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 400,
        "resizable": true,
        "hiddenTitle": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https:; img-src 'self' data: https: blob:; media-src 'self' https:;"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDBBQjA0NjE0RjdCQkM2QjQKUldUbWVqYmNqK0lVU3BvVUQrRm5sMjB0N0lVUGx6RkE5VjRoVHBYU0hJMUdRQnVxV3lZQ2YvVjYK",
      "endpoints": [
        "https://github.com/collaborator-ai/collab-public/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
